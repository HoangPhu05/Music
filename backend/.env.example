# Copy this file to .env and fill real values

# Database (Render Postgres)
# Render usually provides postgres://... or postgresql://...
# The app auto-converts to postgresql+asyncpg://...
DATABASE_URL=postgresql://postgres:password@localhost:5432/musicapp

# JWT
SECRET_KEY=replace-with-a-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://music-frontend-production.up.railway.app

# Storage backend: local (dev) or cloudinary (production)
STORAGE_BACKEND=cloudinary

# Local storage (used when STORAGE_BACKEND=local)
LOCAL_STORAGE_PATH=./uploads

# Cloudinary (used when STORAGE_BACKEND=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=music-app
